# CoralGuard AI — copy to `.env` and set values locally / in production secrets.
#   copy .env.example .env

# Required for LLM marine report (https://console.groq.com/)
GROQ_API_KEY=

# Optional model paths (relative to coralguard-api/ or absolute Windows paths)
CORALGUARD_CNN_PATH=app/models/efficientnet_b3_best.pth
CORALGUARD_DBSCAN_PATH=app/models/dbscan_model.pkl
CORALGUARD_FUSION_PATH=app/models/ann_fusion_best.pth

# Tabular bundle: features.pkl, scaler.pkl, X_train.npy (must align with dbscan_model.pkl labels)
CORALGUARD_TABULAR_DIR=data/tabular

CORALGUARD_DEVICE=auto
CORALGUARD_CNN_IMAGE_SIZE=224
GROQ_MODEL=llama-3.3-70b-versatile
